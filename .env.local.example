# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # server-only, never expose client-side

# Outbound email via Google Apps Script web app (deployed from gas/email-sender.gs)
GAS_EMAIL_WEBHOOK=https://script.google.com/macros/s/XXXX/exec
GAS_EMAIL_SECRET=replace-with-shared-secret
FROM_NAME=Liav
# Optional: send "as" this address. Must be a verified "Send mail as" alias
# of the Gmail account that authorized the GAS web app. Leave blank to send
# from the GAS account's primary address.
FROM_EMAIL=
GMAIL_DAILY_QUOTA=90

# Admin auth
ADMIN_PASSWORD=replace-with-strong-password
ADMIN_COOKIE_SECRET=replace-with-32+byte-hex

# Cron trigger from Vercel (matches Authorization: Bearer $CRON_SECRET)
CRON_SECRET=replace-with-32+byte-hex

# Public site origin (used for unsubscribe links in emails). No trailing slash.
PUBLIC_URL=https://mail-sequence.vercel.app

# Lead-ingest shared secret (called by liav-lead-magnet /api/submit)
INGEST_SECRET=replace-with-32+byte-hex
